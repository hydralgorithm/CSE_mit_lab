   "source": [
    "import pandas as pd \n",
    "import matplotlib.pyplot as plt \n",
    "df = pd.read_csv('../datasets/ipl batting.csv') \n",
    "top = df.groupby('Player')['Runs'].sum().nlargest(5) \n",
    "top.plot(kind='bar') \n",
    "plt.ylabel('Total Runs') \n",
    "plt.title('Top 5 run scorers') \n",
    "plt.savefig('../datasets/ipl_top5_runs.png')"
   ]
  }
 ],
